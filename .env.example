# Copy this to .env and fill in your values

# Azure AI Foundry project endpoint
AZURE_AI_PROJECT_ENDPOINT=

# Azure AI Foundry API key (from your project's Keys & Endpoint page)
AZURE_AI_PROJECT_KEY="your-key-here"

# Model deployment name in your AI Foundry project (e.g. gpt-4o, gpt-4o-mini)
AZURE_OPENAI_MODEL="gpt-4o"

# MCP server URL — use local server for dev, Azure Function URL for prod
# Local dev:  http://localhost:7071/api/mcp
# Azure prod: https://<your-app>.azurewebsites.net/api/mcp
MCP_SERVER_URL="http://localhost:7071/api/mcp"

# Azure Function key — leave empty for local dev
MCP_SERVER_KEY=""
