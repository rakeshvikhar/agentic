# Copy to .env and fill in your values

# AI Foundry project endpoint (injected automatically when deployed to Foundry)
FOUNDRY_PROJECT_ENDPOINT=

# API key for the Foundry project
AZURE_AI_PROJECT_KEY=your-key-here

# Model deployment name in your Foundry project
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.2

# Helpdesk MCP server (Azure Function App deployed earlier)
MCP_SERVER_URL=
MCP_SERVER_KEY=your-function-key-here

# Port for the local server (default 8088)
PORT=8088

# Set by deploy.py after the hosted agent is deployed
# HELPDESK_AGENT_ENDPOINT=https://...services.ai.azure.com/.../agents/helpdesk-langgraph-agent/...
